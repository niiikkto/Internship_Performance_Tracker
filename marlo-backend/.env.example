# Скопируйте в .env и заполните своими значениями

# SQLite (файл marlo_db.db в папке marlo-backend)
DATABASE_URL=sqlite+aiosqlite:///./marlo_db.db

# PostgreSQL — замените строку выше, если БД уже создана как marlo_db:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marlo_db

SECRET_KEY=replace-me-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
